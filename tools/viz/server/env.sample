# ================================
# Kubernetes Management Environment Variables
# ================================
# Copy this file to .env and fill in your actual values

# ================================
# Kubernetes Configuration
# ================================

# Optional: Path to your kubeconfig file
# If not set, will try ~/.kube/config or in-cluster config
KUBECONFIG=/path/to/your/kubeconfig

# Optional: Default Kubernetes namespace
# Defaults to 'default' if not set
K8S_NAMESPACE=default

# ================================
# PostgreSQL Database Configuration
# ================================

# Required: Database credentials for postgres operations
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Optional: Database name (defaults to 'djibouti_egov')
DB_NAME=djibouti_egov

# Optional: Database host (defaults to 'localhost' when using port-forward)
DB_HOST=localhost

# Optional: Database port (defaults to 5432)
DB_PORT=5432

# ================================
# AWS Configuration (for EKS)
# ================================

# Optional: AWS credentials if using EKS
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# ================================
# Application Configuration
# ================================

# Optional: Server port (defaults to 8001)
PORT=8001

# Optional: Proxy target for API requests
PROXY_TARGET=https://djibouti.tekdinext.com

# Optional: Log level for debugging
LOG_LEVEL=info

# ================================
# Development Configuration
# ================================

# Optional: Enable development mode features
NODE_ENV=development

# Optional: Enable detailed logging for k8s operations
DEBUG_K8S=false

# Optional: Enable detailed logging for database operations  
DEBUG_DB=false

# ================================
# Security Configuration
# ================================

# Optional: Maximum query timeout in milliseconds (defaults to 30000)
QUERY_TIMEOUT=30000

# Optional: Maximum buffer size for command output (defaults to 1MB)
MAX_BUFFER_SIZE=1048576

# ================================
# Example Values for Development
# ================================
# 
# For local development with minikube:
# K8S_NAMESPACE=default
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=djibouti_egov
#
# For EKS cluster:
# K8S_NAMESPACE=egov
# AWS_DEFAULT_REGION=us-west-2
# KUBECONFIG=/home/user/.kube/eks-config
#
# For production:
# NODE_ENV=production
# LOG_LEVEL=warn
# QUERY_TIMEOUT=60000
