{
    "name": "djibouti-egov-viz-proxy",
    "version": "1.0.0",
    "description": "Dev proxy and static server for Djibouti eGov Visualization Tools",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "NODE_ENV=development node server.js",
        "setup": "npm install && cp env.sample .env && echo '✅ Setup complete! Edit .env file with your configuration and run: npm start'",
        "test": "jest --detectOpenHandles --forceExit",
        "test:watch": "jest --watch --detectOpenHandles",
        "test:coverage": "jest --coverage --detectOpenHandles --forceExit",
        "test:e2e": "NODE_ENV=test jest --testPathPattern=e2e --detectOpenHandles --forceExit"
    },
    "dependencies": {
        "@kubernetes/client-node": "^1.3.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "http-proxy-middleware": "^2.0.6",
        "js-yaml": "^4.1.0",
        "pg": "^8.11.3",
        "serve-index": "^1.9.1"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "supertest": "^6.3.3",
        "nock": "^13.5.0",
        "@types/jest": "^29.5.8",
        "jest-environment-node": "^29.7.0"
    },
    "jest": {
        "testEnvironment": "node",
        "testTimeout": 30000,
        "setupFilesAfterEnv": [
            "<rootDir>/tests/setup.js"
        ],
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/dist/"
        ],
        "collectCoverageFrom": [
            "*.js",
            "!node_modules/**",
            "!tests/**",
            "!coverage/**"
        ]
    }
}